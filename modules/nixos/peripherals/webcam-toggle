#!/usr/bin/env bash
set -euo pipefail

# State lives in a root-owned dir: this script runs as root via a NOPASSWD
# sudo rule, so it must never trust user-writable input (a planted /tmp state
# file would turn the `echo > $p/authorized` writes into arbitrary root file
# writes).
ACTION="${1:-toggle}"
STATE_DIR="/run/webcam-toggle"
STATE_FILE="$STATE_DIR/usb-paths"

find_webcam_usb_dirs() {
  declare -A seen
  for vdir in /sys/class/video4linux/video*; do
    [ -d "$vdir" ] || continue
    real="$(readlink -f "$vdir/device")"
    dir="$real"
    while [ "$dir" != "/" ]; do
      if [ -f "$dir/authorized" ] && [ -f "$dir/idVendor" ]; then
        if [[ -z "${seen[$dir]+x}" ]]; then
          seen[$dir]=1
          echo "$dir"
        fi
        break
      fi
      dir="$(dirname "$dir")"
    done
  done
}

# Belt-and-braces for anything read back from state: only accept entries that
# resolve to a real USB device dir under /sys/devices.
validate_saved_paths() {
  local p real
  while IFS= read -r p; do
    real="$(readlink -f "$p")" || continue
    [[ "$real" == /sys/devices/* ]] || continue
    [[ -f "$real/authorized" && -f "$real/idVendor" ]] || continue
    echo "$real"
  done
}

# Get paths from live detection, falling back to saved state (needed for `on`:
# a deauthorized camera no longer appears under /sys/class/video4linux)
paths=$(find_webcam_usb_dirs)
if [[ -z "$paths" && -f "$STATE_FILE" ]]; then
  paths=$(validate_saved_paths < "$STATE_FILE")
fi

if [[ -z "$paths" ]]; then
  echo "No cameras found"
  exit 0
fi

case "$ACTION" in
  on)
    for p in $paths; do echo 1 > "$p/authorized"; done
    rm -f "$STATE_FILE"
    echo "Cameras authorized"
    ;;
  off)
    mkdir -p "$STATE_DIR"
    echo "$paths" > "$STATE_FILE"
    for p in $paths; do echo 0 > "$p/authorized"; done
    echo "Cameras deauthorized"
    ;;
  toggle)
    any_on=0
    for p in $paths; do
      if [[ "$(cat "$p/authorized")" == "1" ]]; then
        any_on=1
        break
      fi
    done
    if [[ "$any_on" == "1" ]]; then
      mkdir -p "$STATE_DIR"
      echo "$paths" > "$STATE_FILE"
      for p in $paths; do echo 0 > "$p/authorized"; done
      echo "Cameras deauthorized"
    else
      for p in $paths; do echo 1 > "$p/authorized"; done
      rm -f "$STATE_FILE"
      echo "Cameras authorized"
    fi
    ;;
  status)
    for p in $paths; do
      name="unknown"
      [[ -f "$p/product" ]] && name="$(cat "$p/product")"
      auth="$(cat "$p/authorized")"
      if [[ "$auth" == "1" ]]; then
        echo "$name: authorized"
      else
        echo "$name: deauthorized"
      fi
    done
    ;;
  *)
    echo "Usage: webcam-toggle [on|off|toggle|status]"
    exit 1
    ;;
esac
